# ============================================================================
# Klik_IT — Apache config
# ============================================================================
# This file lives in public/ so Vite copies it verbatim to dist/ during build.
# In production, the served document root must be dist/ (or this file
# manually copied alongside the served HTML) for the rules to take effect.
# ============================================================================

# Custom 404 page — leading slash points to the served document root.
ErrorDocument 404 /404.html
